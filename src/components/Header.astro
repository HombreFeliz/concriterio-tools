---
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-name">con criterio</span>
      <span class="logo-badge">tools</span>
    </a>

    <button class="burger" id="burger" aria-label="Abrir menú" aria-expanded="false">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>

    <nav class="nav" id="nav">
      <a href="https://concriterio.blog" target="_blank" rel="noopener">Newsletter</a>
      <a href="https://concriterio.dev" target="_blank" rel="noopener">Recursos</a>
      <a href="https://github.com/HombreFeliz" target="_blank" rel="noopener">GitHub</a>
      <button class="text-size-toggle" id="text-size-toggle" aria-label="Cambiar tamaño de texto" title="Texto más grande">
        Aa
      </button>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('text-size-toggle');
  const stored = localStorage.getItem('text-large');
  if (stored === 'true') {
    document.body.classList.add('text-large');
    toggle?.classList.add('active');
  }
  toggle?.addEventListener('click', () => {
    const isLarge = document.body.classList.toggle('text-large');
    toggle.classList.toggle('active', isLarge);
    localStorage.setItem('text-large', String(isLarge));
  });

  const burger = document.getElementById('burger');
  const nav = document.getElementById('nav');
  burger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    burger.classList.toggle('open', isOpen);
    burger.setAttribute('aria-expanded', String(isOpen));
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      nav.classList.remove('open');
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 16px var(--padding-x);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .logo-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }

  .logo-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--primary);
    background: var(--primary-muted);
    border: 1px solid rgba(118, 101, 255, 0.2);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
  }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 110;
  }

  .burger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .burger.open .burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .burger.open .burger-line:nth-child(2) {
    opacity: 0;
  }

  .burger.open .burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .nav a:hover {
    color: var(--text);
  }

  .text-size-toggle {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 4px 10px;
    cursor: pointer;
    transition: all 0.2s;
    line-height: 1;
  }

  .text-size-toggle:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  .text-size-toggle.active {
    color: var(--primary);
    background: var(--primary-muted);
    border-color: rgba(118, 101, 255, 0.3);
  }

  @media (max-width: 700px) {
    .burger {
      display: flex;
    }

    .nav {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--bg);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 32px;
      z-index: 105;
    }

    .nav.open {
      display: flex;
    }

    .nav a {
      font-size: 1.2rem;
      color: var(--text);
    }

    .text-size-toggle {
      font-size: 1rem;
      padding: 8px 16px;
    }
  }
</style>
